---
interface Role {
  title: string
  company: string
  period: string
  location: string
  description: string
}

const roles: Role[] = [
  {
    title: 'Senior Software Engineer',
    company: 'CNG Holdings Inc',
    period: 'Nov 2016 – Present',
    location: 'Cincinnati, OH',
    description:
      'Architecting full-stack systems across React/Next.js, Node.js, Serverless, AWS, and MongoDB in fintech. Built internal tooling that improved development experience, and delivered customer-facing features supporting growth objectives. Established coding standards, led code reviews, and coordinated cross-functional teams from design through production.',
  },
  {
    title: 'Senior Java Engineer',
    company: 'CNG Holdings Peru',
    period: 'Mar 2014 – Nov 2016',
    location: 'Lima, Peru',
    description:
      'Led front-end development of internal compliance dashboards and orchestrated cross-team integration efforts supporting the retail lending business. Diagnosed and triaged issues across testing and production environments, coordinating root-cause analysis and timely resolutions.',
  },
  {
    title: 'Software Developer',
    company: 'Hildebrando Peru',
    period: 'May 2013 – Mar 2014',
    location: 'Lima, Peru',
    description:
      'Delivered solutions using Java, Spring, and JSF for multiple clients. Improved code quality through systematic checks and documented a team style guide to standardize practices.',
  },
  {
    title: 'Software Developer',
    company: 'GMD SA',
    period: 'Jun 2011 – Apr 2013',
    location: 'Lima, Peru',
    description:
      'Contributed to the development of a large-scale budgeting management system for a government entity. Built full-stack applications using JSF, Spring, and Oracle across multiple client engagements.',
  },
]
---

<section
  id="experience"
  aria-labelledby="experience-heading"
  class="scroll-mt-2 py-24 md:py-32"
>
  <div class="mx-auto max-w-5xl px-6">
    <div data-experience-header class="mb-12">
      <span
        aria-hidden="true"
        class="text-accent mb-3 block font-mono text-xs tracking-widest uppercase"
      >
        Experience
      </span>
      <h2
        id="experience-heading"
        class="font-display text-fg text-3xl font-bold tracking-tight md:text-4xl"
      >
        Where I've been
      </h2>
    </div>

    <div class="relative">
      <!-- Vertical connecting line -->
      <div
        class="bg-border absolute top-2 bottom-4 left-4 w-px"
        aria-hidden="true"
      >
      </div>

      <!-- Timeline entries — direct children for staggerChildren -->
      <ol data-timeline class="space-y-12">
        {
          roles.map((role) => (
            <li class="relative pl-10 sm:pl-12">
              <div
                class="bg-accent ring-base absolute top-1.5 left-4 h-2.5 w-2.5 -translate-x-1/2 rounded-full ring-2"
                aria-hidden="true"
              />

              <h3 class="font-display text-fg text-lg font-semibold">
                {role.title}
              </h3>
              <span class="text-fg-subtle mt-0.5 block text-sm">
                {role.company}
              </span>
              <p class="text-fg-subtle mt-1 font-mono text-xs">
                {role.period} · {role.location}
              </p>
              <p class="text-fg-subtle mt-3 text-sm leading-relaxed">
                {role.description}
              </p>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<script>
  import { revealOnScroll, staggerChildren } from '../lib/animations'

  const header = document.querySelector<HTMLElement>(
    '#experience [data-experience-header]',
  )
  if (header) {
    header.setAttribute('data-animate', '')
    revealOnScroll(Array.from(header.children) as HTMLElement[])
  }

  const timeline = document.querySelector<HTMLElement>(
    '#experience [data-timeline]',
  )
  if (timeline) {
    timeline.setAttribute('data-animate', '')
    staggerChildren(timeline)
  }
</script>
