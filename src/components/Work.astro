---
interface Project {
  name: string
  type: 'Personal Project' | 'Open Source Contribution' | 'Professional'
  org?: string
  description: string
  tech: string[]
  source?: string
}

const projects: Project[] = [
  {
    name: 'Consumer Lending Platform',
    type: 'Professional',
    description:
      'Architected and shipped customer-facing features across a consumer lending platform — loan origination, account management, and payment flows. Built event-driven backend services on AWS and integrated financial data providers for real-time decisioning.',
    tech: [
      'React',
      'TypeScript',
      'Node.js',
      'Serverless',
      'Openapi',
      'AWS',
      'MongoDB',
    ],
  },
  {
    name: 'Engineering Tooling & Platform',
    type: 'Professional',
    description:
      'Designed and maintained internal developer tooling to reduce friction across the SDLC — shared component libraries, CI/CD pipeline improvements, and observability integrations that shortened the feedback loop from development to production.',
    tech: ['React', 'Node.js', 'Jest', 'Sentry', 'LaunchDarkly'],
  },
  {
    name: 'customize-cra',
    type: 'Open Source Contribution',
    description:
      "Contributed to customize-cra, a utility for extending Create React App's webpack configuration without ejecting. Used across thousands of projects to bridge CRA conventions with custom build requirements.",
    tech: ['JavaScript', 'Create React App'],
    source: 'https://github.com/arackaf/customize-cra',
  },
  {
    name: 'rodrigonarvaez.com',
    type: 'Personal Project',
    description:
      'This site. Static-first with Astro, Tailwind CSS v4 design tokens, and GSAP scroll-driven animations. Dark/light theme system with no-flash init. 98 Lighthouse performance score, 100 on accessibility.',
    tech: ['Astro', 'TypeScript', 'Tailwind CSS', 'GSAP'],
    source: 'https://github.com/rodrigonarvaez/rodrigonarvaez.com',
  },
]
---

<section
  id="work"
  aria-labelledby="work-heading"
  class="scroll-mt-2 py-24 md:py-32"
>
  <div class="mx-auto max-w-5xl px-6">
    <div data-work-header class="mb-12">
      <span
        aria-hidden="true"
        class="text-accent mb-3 block font-mono text-xs tracking-widest uppercase"
        >Work</span
      >
      <h2
        id="work-heading"
        class="font-display text-fg text-3xl font-bold tracking-tight md:text-4xl"
      >
        Things I've built
      </h2>
    </div>

    <div data-work-grid class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {
        projects.map((project) => (
          <article class="border-border bg-raised hover:border-accent flex flex-col rounded-xl border p-6 transition-all duration-300 hover:-translate-y-1">
            <header class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
              <div>
                <h3 class="font-display text-fg text-lg font-semibold">
                  {project.name}
                </h3>
                {project.org && (
                  <p class="text-fg-subtle mt-0.5 text-xs">{project.org}</p>
                )}
              </div>
              <span
                class={`bg-high text-accent-text shrink-0 rounded-full px-2.5 py-0.5 text-xs font-medium`}
              >
                {project.type}
              </span>
            </header>

            <p class="text-fg-subtle mb-4 flex-1 text-sm leading-relaxed">
              {project.description}
            </p>

            <ul class="flex flex-wrap gap-2">
              {project.tech.map((t) => (
                <li class="bg-high text-fg-subtle rounded px-2 py-0.5 font-mono text-xs">
                  {t}
                </li>
              ))}
            </ul>

            {project.source && (
              <a
                href={project.source}
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent-text mt-4 self-start text-xs underline-offset-4 hover:underline"
              >
                View source →
              </a>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { revealOnScroll, staggerChildren } from '../lib/animations'

  const header = document.querySelector<HTMLElement>('#work [data-work-header]')
  if (header) {
    header.setAttribute('data-animate', '')
    revealOnScroll(Array.from(header.children) as HTMLElement[])
  }

  const grid = document.querySelector<HTMLElement>('#work [data-work-grid]')
  if (grid) {
    grid.setAttribute('data-animate', '')
    staggerChildren(grid)
  }
</script>
