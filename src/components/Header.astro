---
import ThemeToggle from './ThemeToggle.astro'

const navLinks = [
  { label: 'About', href: '#about' },
  { label: 'Work', href: '#work' },
  { label: 'Experience', href: '#experience' },
  { label: 'Contact', href: '#contact' },
]
---

<header
  data-header
  class="fixed inset-x-0 top-0 z-40 border-b border-transparent"
>
  <div class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6">
    <!-- Monogram logo -->
    <a href="#hero" class="block" aria-label="Rodrigo Narvaez — back to top">
      <svg
        viewBox="0 0 32 32"
        width="30"
        height="30"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
      >
        <rect width="32" height="32" rx="6" fill="var(--color-accent)"></rect>
        <text
          x="16"
          y="22"
          font-family="system-ui, -apple-system, sans-serif"
          font-size="13"
          font-weight="700"
          fill="var(--color-base)"
          text-anchor="middle"
          letter-spacing="-0.5">RN</text
        >
      </svg>
    </a>

    <!-- Right side: desktop nav + theme toggle + mobile hamburger -->
    <div class="flex items-center gap-2">
      <!-- Desktop nav -->
      <nav
        role="navigation"
        aria-label="Main navigation"
        class="mr-2 hidden sm:block"
      >
        <ul class="flex items-center gap-8 text-sm">
          {
            navLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="text-fg-subtle hover:text-fg transition-colors duration-200"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Theme toggle (always visible) -->
      <ThemeToggle />

      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        type="button"
        class="text-fg-subtle hover:text-fg flex h-11 w-11 items-center justify-center rounded transition-colors sm:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          id="icon-open"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg
          id="icon-close"
          class="hidden"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    aria-hidden="true"
    class="border-border bg-base hidden border-t sm:hidden"
  >
    <nav aria-label="Mobile navigation">
      <ul class="flex flex-col px-6 py-2">
        {
          navLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class="text-fg-subtle hover:text-fg flex min-h-11 items-center transition-colors duration-200"
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('[data-header]')!
  const menuToggle = document.getElementById(
    'menu-toggle',
  ) as HTMLButtonElement | null
  const mobileMenu = document.getElementById('mobile-menu')
  const iconOpen = document.getElementById('icon-open')
  const iconClose = document.getElementById('icon-close')

  const reducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  ).matches
  let prevScrollY = window.scrollY
  let menuOpen = false

  // ── Scroll behavior ──────────────────────────────────────────────────────────
  // Background, border, and backdrop-filter are handled entirely by CSS via the
  // [data-scrolled] attribute — no hardcoded colours here, so the header is
  // automatically theme-aware.

  function updateHeader(): void {
    const scrollY = window.scrollY
    const atTop = scrollY < 50
    const scrollingDown = scrollY > prevScrollY

    if (atTop) {
      header.removeAttribute('data-scrolled')
      header.style.transform = ''
    } else {
      header.setAttribute('data-scrolled', '')
      // Hide on scroll down; skip the animation if motion is reduced or menu is open
      if (!reducedMotion && !menuOpen) {
        header.style.transform = scrollingDown ? 'translateY(-100%)' : ''
      }
    }

    prevScrollY = scrollY
  }

  window.addEventListener('scroll', updateHeader, { passive: true })
  updateHeader() // apply correct state on load (e.g. page restored mid-scroll)

  // ── Mobile menu ──────────────────────────────────────────────────────────────

  function openMenu(): void {
    menuOpen = true
    mobileMenu?.classList.remove('hidden')
    mobileMenu?.setAttribute('aria-hidden', 'false')
    menuToggle?.setAttribute('aria-label', 'Close menu')
    menuToggle?.setAttribute('aria-expanded', 'true')
    iconOpen?.classList.add('hidden')
    iconClose?.classList.remove('hidden')
    // Ensure header stays visible while menu is open
    header.style.transform = ''
    // Move focus into the menu so keyboard users are inside it
    const firstLink = mobileMenu?.querySelector<HTMLElement>('a')
    firstLink?.focus()
  }

  function closeMenu(): void {
    menuOpen = false
    mobileMenu?.classList.add('hidden')
    mobileMenu?.setAttribute('aria-hidden', 'true')
    menuToggle?.setAttribute('aria-label', 'Open menu')
    menuToggle?.setAttribute('aria-expanded', 'false')
    iconOpen?.classList.remove('hidden')
    iconClose?.classList.add('hidden')
  }

  menuToggle?.addEventListener('click', () => {
    menuOpen ? closeMenu() : openMenu()
  })

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu)
  })

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menuOpen) {
      closeMenu()
      menuToggle?.focus()
      return
    }

    // Focus trap: keep Tab cycling within the open mobile menu
    if (!menuOpen || e.key !== 'Tab') return

    const focusableLinks = Array.from(
      mobileMenu?.querySelectorAll<HTMLElement>('a') ?? [],
    )
    if (focusableLinks.length === 0) return

    const first = focusableLinks[0]
    const last = focusableLinks[focusableLinks.length - 1]

    if (e.shiftKey) {
      if (document.activeElement === first) {
        e.preventDefault()
        last.focus()
      }
    } else {
      if (document.activeElement === last) {
        e.preventDefault()
        first.focus()
      }
    }
  })
</script>
