---
const navLinks = [
  { label: 'About', href: '#about' },
  { label: 'Work', href: '#work' },
  { label: 'Experience', href: '#experience' },
  { label: 'Contact', href: '#contact' },
]
---

<header data-header class="fixed inset-x-0 top-0 z-40 border-b border-transparent">
  <div class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6">
    <!-- Monogram logo -->
    <a
      href="#hero"
      class="font-display text-xl font-bold text-accent"
      aria-label="Rodrigo Narvaez — back to top"
    >
      RN
    </a>

    <!-- Desktop nav -->
    <nav role="navigation" aria-label="Main navigation" class="hidden sm:block">
      <ul class="flex items-center gap-8 text-sm">
        {
          navLinks.map(({ label, href }) => (
            <li>
              <a href={href} class="text-fg-subtle transition-colors duration-200 hover:text-fg">
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      type="button"
      class="flex h-11 w-11 items-center justify-center rounded text-fg-subtle transition-colors hover:text-fg sm:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        id="icon-open"
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <svg
        id="icon-close"
        class="hidden"
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    aria-hidden="true"
    class="hidden border-t border-border bg-base sm:hidden"
  >
    <nav aria-label="Mobile navigation">
      <ul class="flex flex-col px-6 py-2">
        {
          navLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class="flex min-h-11 items-center text-fg-subtle transition-colors duration-200 hover:text-fg"
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('[data-header]')!
  const menuToggle = document.getElementById('menu-toggle') as HTMLButtonElement | null
  const mobileMenu = document.getElementById('mobile-menu')
  const iconOpen = document.getElementById('icon-open')
  const iconClose = document.getElementById('icon-close')

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
  let prevScrollY = window.scrollY
  let menuOpen = false

  // Apply slide + bg transitions only when motion is allowed.
  // The global prefers-reduced-motion CSS reset (transition-duration: 0.01ms)
  // will kill any transitions we set here anyway, but we also skip
  // the translateY logic entirely to avoid snapping the header off-screen.
  if (!reducedMotion) {
    header.style.transition = [
      'transform 300ms var(--ease-out-expo)',
      'background-color 200ms ease',
      'backdrop-filter 200ms ease',
      'border-color 200ms ease',
    ].join(', ')
  }

  // ── Scroll behavior ──────────────────────────────────────────────────────────

  function updateHeader(): void {
    const scrollY = window.scrollY
    const atTop = scrollY < 50
    const scrollingDown = scrollY > prevScrollY

    if (atTop) {
      header.style.backgroundColor = 'transparent'
      header.style.backdropFilter = ''
      header.style.removeProperty('-webkit-backdrop-filter')
      header.style.borderBottomColor = 'transparent'
      header.style.transform = ''
    } else {
      header.style.backgroundColor = 'rgba(10, 10, 10, 0.85)'
      header.style.backdropFilter = 'blur(12px)'
      header.style.setProperty('-webkit-backdrop-filter', 'blur(12px)')
      header.style.borderBottomColor = 'var(--color-border)'

      // Hide on scroll down; keep visible while mobile menu is open
      if (!reducedMotion && !menuOpen) {
        header.style.transform = scrollingDown ? 'translateY(-100%)' : ''
      }
    }

    prevScrollY = scrollY
  }

  window.addEventListener('scroll', updateHeader, { passive: true })
  updateHeader() // apply correct state on load (e.g. page restored mid-scroll)

  // ── Mobile menu ──────────────────────────────────────────────────────────────

  function openMenu(): void {
    menuOpen = true
    mobileMenu?.classList.remove('hidden')
    mobileMenu?.setAttribute('aria-hidden', 'false')
    menuToggle?.setAttribute('aria-label', 'Close menu')
    menuToggle?.setAttribute('aria-expanded', 'true')
    iconOpen?.classList.add('hidden')
    iconClose?.classList.remove('hidden')
    // Ensure header stays visible while menu is open
    header.style.transform = ''
  }

  function closeMenu(): void {
    menuOpen = false
    mobileMenu?.classList.add('hidden')
    mobileMenu?.setAttribute('aria-hidden', 'true')
    menuToggle?.setAttribute('aria-label', 'Open menu')
    menuToggle?.setAttribute('aria-expanded', 'false')
    iconOpen?.classList.remove('hidden')
    iconClose?.classList.add('hidden')
  }

  menuToggle?.addEventListener('click', () => {
    menuOpen ? closeMenu() : openMenu()
  })

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu)
  })

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menuOpen) closeMenu()
  })
</script>
