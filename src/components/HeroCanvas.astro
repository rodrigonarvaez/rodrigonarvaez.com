---
// HeroCanvas — ambient generative canvas for the hero section.
// Sparse particle constellation: dots drift via quasi-periodic oscillation,
// connected by faint lines when close. Mouse gently repels nearby particles.
// Theme-aware, reduced-motion safe, visibility-paused.
---

<canvas
  id="hero-canvas"
  aria-hidden="true"
  role="presentation"
  class="pointer-events-none absolute inset-0 -z-10 h-full w-full"
></canvas>

<script>
  import gsap from 'gsap'

  // ── Types ──────────────────────────────────────────────────────────
  interface Particle {
    x: number
    y: number
    phase: number   // unique oscillation phase offset
    speed: number   // oscillation rate
    radius: number
    mx: number      // mouse-driven velocity (decays each frame)
    my: number
  }

  type RGB = readonly [number, number, number]

  // ── Constants ──────────────────────────────────────────────────────
  const MAX_DIST = 115    // px — max distance to draw a connection line
  const INFLUENCE_R = 170 // px — mouse repulsion radius
  const DRIFT_AMP = 0.32  // px/frame — oscillation amplitude
  const MOUSE_K = 0.28    // mouse repulsion strength scalar
  const DAMPEN = 0.87     // velocity damping factor per frame

  // ── Canvas setup ───────────────────────────────────────────────────
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement
  const ctx = canvas.getContext('2d')!

  const DPR = Math.min(window.devicePixelRatio || 1, 2)
  const REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches

  // ── State ──────────────────────────────────────────────────────────
  let W = 0
  let H = 0
  let particles: Particle[] = []
  let rafId: number | null = null
  let t0 = 0

  // Mouse — event writes pending values; draw loop reads them once per frame.
  // This avoids running expensive particle math on every mousemove event.
  let mouseX = -9999
  let mouseY = -9999
  let pendingX = -9999
  let pendingY = -9999
  let mouseDirty = false

  // ── Theme-aware colors ─────────────────────────────────────────────
  function parseHex(raw: string): RGB {
    const h = raw.trim().replace(/^#/, '')
    if (h.length !== 6) return [250, 250, 250]
    const n = parseInt(h, 16)
    return [(n >> 16) & 0xff, (n >> 8) & 0xff, n & 0xff] as const
  }

  function readColors(): { accent: RGB } {
    const s = getComputedStyle(document.documentElement)
    return {
      accent: parseHex(s.getPropertyValue('--color-accent')),
    }
  }

  let clr = readColors()

  // Re-read palette when the user switches themes
  new MutationObserver(() => {
    clr = readColors()
  }).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme'],
  })

  // ── Resize ─────────────────────────────────────────────────────────
  function resize(): void {
    const section = canvas.parentElement
    if (!section) return
    W = section.offsetWidth
    H = section.offsetHeight
    canvas.width = Math.round(W * DPR)
    canvas.height = Math.round(H * DPR)
    // setTransform resets the matrix — idempotent on repeated resize calls
    ctx.setTransform(DPR, 0, 0, DPR, 0, 0)
  }

  let resizeTimer = 0
  window.addEventListener(
    'resize',
    () => {
      clearTimeout(resizeTimer)
      resizeTimer = window.setTimeout(() => {
        resize()
        // Clamp any particles that ended up outside the new bounds
        for (const p of particles) {
          if (p.x > W) p.x = Math.random() * W
          if (p.y > H) p.y = Math.random() * H
        }
      }, 150)
    },
    { passive: true },
  )

  // ── Particles ──────────────────────────────────────────────────────
  function spawnParticles(): void {
    const count = Math.max(60, Math.min(100, Math.floor((W * H) / 9_000)))
    particles = Array.from({ length: count }, () => ({
      x: Math.random() * W,
      y: Math.random() * H,
      phase: Math.random() * Math.PI * 2,
      speed: 0.07 + Math.random() * 0.11,
      radius: 1.5 + Math.random() * 1.5,
      mx: 0,
      my: 0,
    }))
  }

  // ── Draw ───────────────────────────────────────────────────────────
  function draw(elapsed: number): void {
    ctx.clearRect(0, 0, W, H)

    const s = elapsed * 0.001 // convert to seconds for oscillation calc

    // Consume mouse update at most once per frame
    if (mouseDirty) {
      mouseX = pendingX
      mouseY = pendingY
      mouseDirty = false
    }

    const { accent } = clr
    const acStr = `${accent[0]},${accent[1]},${accent[2]}`

    // ── Update positions ─────────────────────────────────────────────
    // Each particle follows a unique quasi-periodic Lissajous-like path.
    // The irrational frequency ratio (0.83 / 1.37) means paths never
    // exactly repeat, keeping the motion organic and non-mechanical.
    for (const p of particles) {
      p.x += Math.cos(p.phase + s * p.speed) * DRIFT_AMP
      p.y += Math.sin(p.phase * 1.37 + s * p.speed * 0.83) * DRIFT_AMP

      // Mouse repulsion — falls off linearly with distance
      const dx = p.x - mouseX
      const dy = p.y - mouseY
      const dSq = dx * dx + dy * dy
      if (dSq < INFLUENCE_R * INFLUENCE_R && dSq > 0.1) {
        const d = Math.sqrt(dSq)
        const f = (1 - d / INFLUENCE_R) * MOUSE_K
        p.mx += (dx / d) * f
        p.my += (dy / d) * f
      }

      p.x += p.mx
      p.y += p.my
      p.mx *= DAMPEN
      p.my *= DAMPEN

      // Wrap with a soft margin so particles re-enter smoothly
      if (p.x < -20) p.x = W + 20
      else if (p.x > W + 20) p.x = -20
      if (p.y < -20) p.y = H + 20
      else if (p.y > H + 20) p.y = -20
    }

    // ── Connection lines ─────────────────────────────────────────────
    // Alpha fades linearly with distance — sparse and precise.
    ctx.lineWidth = 0.5
    const maxDistSq = MAX_DIST * MAX_DIST
    for (let i = 0; i < particles.length - 1; i++) {
      const a = particles[i]
      for (let j = i + 1; j < particles.length; j++) {
        const b = particles[j]
        const dx = a.x - b.x
        const dy = a.y - b.y
        const dSq = dx * dx + dy * dy
        if (dSq >= maxDistSq) continue
        const d = Math.sqrt(dSq)
        const alpha = ((1 - d / MAX_DIST) * 0.055).toFixed(3)
        ctx.strokeStyle = `rgba(${acStr},${alpha})`
        ctx.beginPath()
        ctx.moveTo(a.x, a.y)
        ctx.lineTo(b.x, b.y)
        ctx.stroke()
      }
    }

    // ── Dots — single batched path, all accent ───────────────────────
    ctx.fillStyle = `rgba(${acStr},0.18)`
    ctx.beginPath()
    for (const p of particles) {
      ctx.moveTo(p.x + p.radius, p.y)
      ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2)
    }
    ctx.fill()
  }

  // ── RAF loop ───────────────────────────────────────────────────────
  function loop(ts: number): void {
    if (t0 === 0) t0 = ts
    draw(ts - t0)
    rafId = requestAnimationFrame(loop)
  }

  function stopRaf(): void {
    if (rafId !== null) {
      cancelAnimationFrame(rafId)
      rafId = null
    }
  }

  // Pause when the tab is hidden — no wasted CPU on invisible frames
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      stopRaf()
    } else if (!REDUCED) {
      t0 = 0 // reset time reference so elapsed stays smooth on resume
      rafId = requestAnimationFrame(loop)
    }
  })

  // ── Mouse tracking ─────────────────────────────────────────────────
  window.addEventListener(
    'mousemove',
    (e) => {
      pendingX = e.clientX
      pendingY = e.clientY
      mouseDirty = true
    },
    { passive: true },
  )

  // ── Bootstrap ──────────────────────────────────────────────────────
  resize()
  spawnParticles()

  if (REDUCED) {
    // Static ambient texture — draw a single frame, no loop
    canvas.style.opacity = '0.45'
    draw(0)
  } else {
    // Fade in after heroReveal settles (~1.2s). Canvas starts invisible,
    // materialises slowly so text reads first, canvas follows.
    gsap.set(canvas, { opacity: 0 })
    rafId = requestAnimationFrame(loop)
    gsap.to(canvas, { opacity: 1, duration: 2, delay: 0.8, ease: 'power2.out' })
  }
</script>
