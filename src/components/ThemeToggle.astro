---

---

<button
  data-theme-toggle
  type="button"
  aria-label="Switch to light mode"
  class="text-fg-subtle hover:text-fg flex h-11 w-11 items-center justify-center rounded transition-colors duration-200"
>
  <!-- Sun icon — visible in dark mode; click switches to light -->
  <svg
    data-theme-icon-sun
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
    ></path>
  </svg>

  <!-- Moon icon — visible in light mode; click switches to dark -->
  <svg
    data-theme-icon-moon
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script>
  const btn = document.querySelector<HTMLButtonElement>('[data-theme-toggle]')
  const html = document.documentElement

  function getTheme(): string {
    return html.getAttribute('data-theme') ?? 'dark'
  }

  function setAriaLabel(theme: string): void {
    btn?.setAttribute(
      'aria-label',
      theme === 'light' ? 'Switch to dark mode' : 'Switch to light mode',
    )
  }

  function applyTheme(theme: string): void {
    html.classList.add('theme-transitioning')
    html.setAttribute('data-theme', theme)
    try {
      localStorage.setItem('theme', theme)
    } catch (_) {
      // Private browsing — silently ignore
    }
    setAriaLabel(theme)
    setTimeout(() => html.classList.remove('theme-transitioning'), 300)
  }

  // Sync aria-label with the theme already applied by the inline head script
  setAriaLabel(getTheme())

  btn?.addEventListener('click', () => {
    applyTheme(getTheme() === 'dark' ? 'light' : 'dark')
  })
</script>
